+	if( i < MAX_INVENTORY ) {
+		ARR_FIND(0, MAX_ITEM_RDM_OPT, k, sd->inventory.u.items_inventory[i].option[k].id == id);
+		if( k < MAX_ITEM_RDM_OPT )
+			script_pushint(st, k);
+		else
+			script_pushint(st, -1);
